# ---- Server-only data access (service_role) ------------------------------
# Used by lib/supabase.ts → getSupabaseServer() for reading the dashboard
# views. Bypasses RLS. NEVER expose to the browser.

# Supabase project URL — Settings → API → Project URL
SUPABASE_URL=

# Service role secret — Settings → API → service_role secret.
# Server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# ---- Auth flow (anon key, magic links) -----------------------------------
# Used by lib/supabase/{browser,server,proxy}.ts for sign-in / sign-out.
# The NEXT_PUBLIC_ prefix is required so the browser bundle can read them.
# The anon key is safe to ship to the client.

# Same Supabase project URL as above, just re-exposed under a public name.
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — Settings → API → "anon" "public" key.
# DIFFERENT from SUPABASE_SERVICE_ROLE_KEY — do not mix them up.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
