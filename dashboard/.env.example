# ---- Server-only data access (service_role) ------------------------------
# Used by lib/supabase.ts → getSupabaseServer() for reading the dashboard
# views. Bypasses RLS. NEVER expose to the browser.

# Supabase project URL — Settings → API → Project URL
SUPABASE_URL=

# Service role secret — Settings → API → service_role secret.
# Server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# ---- Auth flow (anon key, magic links) -----------------------------------
# Used by lib/supabase/{browser,server,proxy}.ts for sign-in / sign-out.
# The NEXT_PUBLIC_ prefix is required so the browser bundle can read them.
# The anon key is safe to ship to the client.

# Same Supabase project URL as above, just re-exposed under a public name.
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — Settings → API → "anon" "public" key.
# DIFFERENT from SUPABASE_SERVICE_ROLE_KEY — do not mix them up.
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ---- Dynamics sync (Phase 6a) --------------------------------------------
# Used by the nightly Vercel Cron sync (app/api/sync-dynamics) and lib/sync/*.
# OAuth2 client-credentials against Azure AD — no bearer tokens stored here.
# Set all of these in Vercel project settings (Production scope) as well.
#
# IMPORTANT: these AZURE_* creds are for the DYNAMICS app registration only —
# the one registered as a Dataverse Application User. They are a DIFFERENT
# Azure app from the Graph/calendar GRAPH_* creds below. Do not point one at
# the other: giving AZURE_* the calendar app's id breaks the sync with
# Dataverse "user is not a member of the organization".

# Azure AD tenant (directory) ID for the Dynamics app.
AZURE_TENANT_ID=

# Application (client) ID of the Dynamics Azure AD app registration.
AZURE_CLIENT_ID=

# Client secret for the Dynamics app. Server-only — never expose to the browser.
AZURE_CLIENT_SECRET=

# Dynamics environment base URL, no trailing slash, e.g.
# https://clientcrm.crm.dynamics.com
DYNAMICS_BASE_URL=

# Shared secret guarding /api/sync-dynamics. Vercel Cron sends it as
# `Authorization: Bearer ${CRON_SECRET}`; the "Run sync now" button reuses it
# server-side. Generate a long random value (e.g. `openssl rand -hex 32`).
CRON_SECRET=


# ---- Microsoft Graph calendar (free/busy) --------------------------------
# Used by lib/graph/* for calendar free/busy lookups via Microsoft Graph.
# OAuth2 client-credentials, app-only. Set these in Vercel too (Production).
#
# IMPORTANT: this is a SEPARATE Azure app from the Dynamics AZURE_* app above.
# The Graph app has application permission `Calendars.ReadBasic.All`
# (admin-consented) and NO Dataverse access; the Dynamics app is the reverse.
# Keeping them on distinct env vars is what prevents the two from colliding.

# Azure AD tenant (directory) ID for the Graph app. (Often the same directory
# as AZURE_TENANT_ID, but keep it explicit — it belongs to a different app.)
GRAPH_TENANT_ID=

# Application (client) ID of the Graph/calendar Azure AD app registration.
GRAPH_CLIENT_ID=

# Client secret for the Graph app. Server-only — never expose to the browser.
GRAPH_CLIENT_SECRET=
